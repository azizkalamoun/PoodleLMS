# Environment Variables Template - Copy to .env and fill in your values
# NEVER commit .env file to Git - use .env.example as template
# Last Updated: March 22, 2026

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_USERNAME=poodle
DB_PASSWORD=your_secure_password_here
DB_URL=jdbc:postgresql://localhost:5432/poodle_lms

# ==========================================
# JWT SECURITY
# ==========================================
# Generate new secret: openssl rand -base64 32
JWT_SECRET=c2VjdXJlLXNlY3JldC1rZXktZm9yLXBvb2RsZS1sbXMtYXBwbGljYXRpb24tMjAyNg==
JWT_EXPIRATION_MS=86400000

# ==========================================
# CORS CONFIGURATION
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# ==========================================
# GOOGLE GEMINI API
# ==========================================
# Get free API key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ==========================================
# SERVER CONFIGURATION
# ==========================================
SERVER_PORT=8081

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SECURITY=DEBUG
LOG_LEVEL_HIBERNATE=WARN

# ==========================================
# APPLICATION PROFILES
# ==========================================
SPRING_PROFILES_ACTIVE=dev
